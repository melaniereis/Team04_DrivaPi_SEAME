[Unit]
Description=pipewire-pulse (system-mode) for DrivaPi
After=pipewire-system.service wireplumber-system.service
Requires=pipewire-system.service
Wants=wireplumber-system.service

[Service]
Type=simple
Environment=XDG_RUNTIME_DIR=/run/pipewire
Environment=PIPEWIRE_RUNTIME_DIR=/run/pipewire
ExecStart=/usr/bin/pipewire-pulse
Restart=on-failure

[Install]
WantedBy=multi-user.target
