# Traceability reports (regenerated, don't commit)
artifacts/traceability/*.csv
artifacts/traceability/*.md
artifacts/traceability/*.json
# except for
!artifacts/traceability/.gitkeep

# TSF Verification Artifacts (DO NOT COMMIT - Ephemeral Evidence)
# These are generated by CI/Scripts and used for validation, but must not be stored in Git.
artifacts/verification/coverage/*
artifacts/verification/tests/*
artifacts/verification/static_analysis/*
artifacts/verification/static_analysis/*

# Ignore the final HTML report (it should be a CI Download, not a file in the repo)
trustable_report.html
TSF_Report.html

# Keep Trustable reports for review
!artifacts/trustable-report/
!artifacts/trustable-report/**

# Keep baselines (important for audit trail)
!artifacts/baselines/
!artifacts/baselines/**

# Build artifacts
*.o
*.a
*.so
*.dylib
*.exe
*.out
*.app

